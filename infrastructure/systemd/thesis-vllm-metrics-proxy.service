[Unit]
Description=Thesis vLLM Metrics Proxy
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=dogukantopcu
WorkingDirectory=/home/dogukantopcu/thesis-proxy-src
Environment=PYTHONPATH=/home/dogukantopcu/thesis-proxy-src
Environment=THESIS_VLLM_UPSTREAM=http://127.0.0.1:8001/v1
Environment=THESIS_PROXY_PORT=8000
ExecStart=/home/dogukantopcu/thesis-proxy-venv/bin/python /home/dogukantopcu/thesis-proxy-src/infrastructure/vllm/metrics_proxy.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
