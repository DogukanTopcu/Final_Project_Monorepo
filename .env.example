# Copy to .env and fill in your values
# Never commit .env to version control

# OpenAI
OPENAI_API_KEY=sk-...

# Together AI (for Llama 3 70B)
TOGETHER_API_KEY=...

# Hugging Face (for dataset downloads)
HF_TOKEN=...

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# AWS (optional, for S3/DynamoDB/EC2)
THESIS_AWS_REGION=eu-west-1
THESIS_S3_RESULTS_BUCKET=thesis-results-dev
THESIS_S3_ARTIFACTS_BUCKET=thesis-artifacts-dev
THESIS_DYNAMODB_TABLE=thesis-experiments
THESIS_ENVIRONMENT=dev

# FastAPI CORS
THESIS_CORS_ORIGINS=["http://localhost:3000"]
