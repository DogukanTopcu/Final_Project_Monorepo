# Copy to .env and fill in real values.
# Never commit .env.

# ------------------------------------------------------------------
# Hugging Face
# ------------------------------------------------------------------

# Required for gated model downloads and dataset access.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# MLflow
# ------------------------------------------------------------------

MLFLOW_TRACKING_URI=http://127.0.0.1:5000
THESIS_MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# ------------------------------------------------------------------
# Remote vLLM endpoints
# ------------------------------------------------------------------

# SLM tier
VLLM_QWEN35_4B_URL=http://<L4_QWEN_IP>:8000/v1
VLLM_GEMMA4_E4B_URL=http://<L4_GEMMA_IP>:8000/v1
VLLM_LLAMA32_3B_URL=http://<L4_LLAMA_IP>:8000/v1

# Mid-tier RTX6000 shared host
VLLM_GPT_OSS_20B_URL=http://<RTX_IP>:8000/v1
VLLM_QWEN35_27B_URL=http://<RTX_IP>:8000/v1
VLLM_GEMMA4_31B_URL=http://<RTX_IP>:8000/v1
VLLM_QWEN35_35B_A3B_URL=http://<RTX_IP>:8000/v1
VLLM_GEMMA4_26B_A4B_URL=http://<RTX_IP>:8000/v1

# Heavy host
VLLM_LLAMA33_70B_URL=http://<HEAVY_IP>:8000/v1
VLLM_GPT_OSS_120B_URL=http://<HEAVY_IP>:8000/v1

# ------------------------------------------------------------------
# Optional hosted API keys
# ------------------------------------------------------------------

OPENAI_API_KEY=
THESIS_OPENAI_API_KEY=

GEMINI_API_KEY=
THESIS_GEMINI_API_KEY=

TOGETHER_API_KEY=
THESIS_TOGETHER_API_KEY=

# ------------------------------------------------------------------
# Energy / infra estimation overrides
# ------------------------------------------------------------------

# Optional JSON override for host pricing or power estimates.
# Example:
# {"gpt-oss-20b":{"host_label":"custom","hourly_usd":2.8,"gpu_power_w":340}}
THESIS_MODEL_RESOURCE_OVERRIDES_JSON=

# Default grid carbon factor used in estimated CO2 calculations.
THESIS_GRID_CO2_G_PER_KWH=380

# ------------------------------------------------------------------
# Results / API
# ------------------------------------------------------------------

THESIS_RESULTS_DIR=results
THESIS_CORS_ORIGINS=["http://localhost:3000"]

# ------------------------------------------------------------------
# Shared RTX6000 mid-tier host auto-switch
# ------------------------------------------------------------------

THESIS_RTX6000_AUTOSWITCH_ENABLED=true
THESIS_RTX6000_INSTANCE_NAME=dogukan-topcu-rtx6000-spot
THESIS_RTX6000_PROJECT=hubx-ml-playground
THESIS_RTX6000_ZONE=europe-west2-c
THESIS_RTX6000_SWITCH_SCRIPT=~/run-mid-llm.sh
THESIS_RTX6000_SWITCH_COMMAND_TIMEOUT_S=180
THESIS_RTX6000_SWITCH_POLL_TIMEOUT_S=1800
THESIS_RTX6000_LOCK_TIMEOUT_S=21600
THESIS_RTX6000_POLL_INTERVAL_S=5
