FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir mlflow google-cloud-storage
ENV PYTHONUNBUFFERED=1
EXPOSE 5000
CMD ["mlflow", "server", \
     "--host", "0.0.0.0", \
     "--port", "5000", \
     "--backend-store-uri", "sqlite:///mlflow.db", \
     "--default-artifact-root", "${MLFLOW_ARTIFACT_ROOT:-./mlartifacts}"]
